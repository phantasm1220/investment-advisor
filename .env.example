# ============================================================
#  .env — 投資助言システム設定
#  GEMINI_API_KEY と DISCORD_WEBHOOK_URL は .default に記載済みのため不要
#  このファイルはそのままコピーして使用可能（書き換え不要）
# ============================================================

# 使用モデル（gemini-2.5-flash-lite = 2.0-flashと同料金で高性能）
LLM_MODEL=gemini-2.5-flash-lite

# Gemini APIエンドポイント（このままでOK）
CCR_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── アプリ設定（変更不要） ─────────────────────────────────
CONFIDENCE_THRESHOLD=0.70
KELLY_FRACTION=0.5
LOG_LEVEL=INFO
LOG_DIR=logs
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=5
